{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2024",
    "lib": ["DOM", "ES2024"],
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "noUncheckedSideEffectImports": false,
    "strict": true,
    "importHelpers": true,
    "resolveJsonModule": true
  }
}
